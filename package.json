{
  "name": "e-act",
  "version": "1.4.269",
  "description": "Système de Gestion des États Civils",
  "author": "SGEC",
  "main": "main.js",
  "build": {
    "appId": "com.sgec.e-act",
    "productName": "E-Act SGEC",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "frontend/build/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "installerHeaderIcon": "assets/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "E-Act SGEC"
    }
  },
  "scripts": {
    "electron": "electron .",
    "frontend:build": "cd frontend && npm run build",
    "dist": "npm run frontend:build && electron-builder --win --x64",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^37.2.5",
    "electron-builder": "^26.15.3"
  }
}
